  <div class="sidebar-divider" data-v-0323cc8d=""></div><!-- Navigation -->
  <nav data-v-0323cc8d="" class="sidebar-nav" aria-label="روابط التنقل"><a data-v-0323cc8d="" href="/dashboard" class="nav-item nav-item--active" title="لوحة التحكم"><span data-v-0323cc8d="" class="nav-icon" aria-hidden="true"><span data-v-0323cc8d="" class="icon-stub" data-icon="home"></span></span><span data-v-0323cc8d="" class="nav-label">لوحة التحكم</span></a><a data-v-0323cc8d="" href="/users" class="nav-item" title="المستخدمون"><span data-v-0323cc8d="" class="nav-icon" aria-hidden="true"><span data-v-0323cc8d="" class="icon-stub" data-icon="users"></span></span><span data-v-0323cc8d="" class="nav-label">المستخدمون</span></a></nav><!-- User section at bottom -->
  <div data-v-0323cc8d="" class="sidebar-footer">
