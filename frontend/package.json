{
  "name": "yemen-flow-hub-frontend",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "generate": "nuxt generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:strict": "eslint . --max-warnings=0",
    "prepare": "husky",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && node scripts/patch-vue-router-volar.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test --project=e2e",
    "test:visual": "playwright test --project=visual",
    "test:visual:update": "playwright test --project=visual --update-snapshots",
    "test:watch": "vitest",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.1",
    "@lucide/vue": "^1.16.0",
    "@pinia/nuxt": "^0.9.0",
    "@tanstack/vue-table": "^8.21.3",
    "@unovis/vue": "^1.6.5",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^13.9.0",
    "@vueuse/nuxt": "^13.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-vue": "^8.6.0",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^4.4.6",
    "pinia": "^2.3.1",
    "reka-ui": "^2.9.8",
    "shadcn-nuxt": "^2.7.3",
    "shadcn-vue": "^2.7.3",
    "tailwind-merge": "^3.6.0",
    "uqr": "^0.1.3",
    "vaul-vue": "^0.4.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.13",
    "vue-boring-avatars": "^1.4.0",
    "vue-input-otp": "^0.3.2",
    "vue-router": "^4.5.0",
    "vue-sonner": "^2.0.9",
    "zod": "^3.24.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "maplibre-gl",
      "unrs-resolver",
      "vue-demi"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@nuxt/eslint": "^1.9.0",
    "@nuxt/test-utils": "^3.19.0",
    "@pinia/testing": "^0.1.6",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.15.17",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^9.39.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tailwindcss": "^4.1.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4",
    "vue-tsc": "^3.3.3"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
