<?xml version="1.0" encoding="UTF-8"?>
<!--
    Standalone config for tests/Integration, deliberately separate from
    phpunit.xml so a bare `php artisan test` / `phpunit` invocation (which
    runs every testsuite phpunit.xml declares, with no implicit exclusion)
    can never discover or execute these tests. Run explicitly:

        composer test:mysql-integration
        (or directly: php artisan test with the configuration flag set to
        phpunit.integration.xml)

    See tests/Integration/README.md.
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Integration">
            <directory>tests/Integration</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <ini name="memory_limit" value="512M"/>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_KEY" value="base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="/>
        <env name="APP_TIMEZONE" value="UTC"/>
        <!-- The default (SQLite) connection this app boots under still needs
             to exist for createApplication()/service resolution — the
             integration test itself never touches it, it swaps to its own
             mysql_lease_regression_gate connection in setUp(). -->
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="APP_DEMO_ROLE_SWITCH" value="false"/>
        <env name="DEMO_SEED_DATA" value="true"/>
        <env name="DEMO_SEED_SIZE" value="minimal"/>
    </php>
</phpunit>
