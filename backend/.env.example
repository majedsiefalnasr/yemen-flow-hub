APP_NAME="CBY Imports Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Aden
APP_LOCALE=ar

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cby_imports
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
QUEUE_CONNECTION=redis
# Redis queue connection name used by the redis + dedicated `emails` queue connections.
# The email subsystem (Epic 15) runs on its own queue: php artisan queue:work --queue=emails
REDIS_QUEUE_CONNECTION=default
CACHE_STORE=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SESSION_DOMAIN=null
FRONTEND_URL=http://localhost:3000

# Mail
# Local/dev/testing must use Mailpit. Production must override these with the
# official CBY/government SMTP server and must not point to Mailpit.
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=no-reply@yemen-flow-hub.local
MAIL_FROM_NAME="${APP_NAME}"

# OTP / MFA
MFA_ENABLED=false
OTP_TTL_SECONDS=600
MFA_MAX_ATTEMPTS=5
PASSWORD_RESET_OTP_TTL_SECONDS=600
PASSWORD_RESET_MAX_ATTEMPTS=5

# Demo-only role switch (for frontend demo mode)
APP_DEMO_ROLE_SWITCH=false

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Trusted Proxies — set to '*' on staging/production when behind a load balancer or reverse proxy.
# Leave unset (empty) in local development to prevent IP spoofing via X-Forwarded-For.
# TRUSTED_PROXIES=*
